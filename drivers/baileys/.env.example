# WhatsApp Baileys Bridge (QR Code)
#
# [PLANO B] Usar quando Cloud API nao estiver disponivel.
# Conecta via QR Code escaneado com o WhatsApp do numero desejado.
#
# Diferencas para Cloud API:
# - Requer QR scan no celular a cada nova sessao
# - Sessao fica salva em session/ (nao perder!)
# - Precisa de daemon rodando 24/7
# - Tunnel necessario apenas se o bot precisar receber webhooks
#
# Problemas conhecidos:
# - Sessao pode expirar se o numero trocar de celular
# - Reconexao manual se perder a sessao

export BOT_NAME="nfe"
export BOT_PHONE="5544991670539"
export BRIDGE_PORT="3003"
export POLL_INTERVAL="2"

# ── Horario de Atendimento (opcional) ─────────────────────────────────
export BUSINESS_HOUR_START="8"
export BUSINESS_HOUR_END="18"
export BUSINESS_DAYS="1,2,3,4,5"
export BUSINESS_TZ="America/Sao_Paulo"
